# Copy this file to .env and fill in real secrets. Do NOT commit .env to version control.
BASE_URL=http://localhost:3000/


MAILERLITE_API_KEY=your-mailerlite-api-key
MAILERSEND_API_KEY=your-mailersend-api-key
# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
BUNNYCDN_STORAGE_ZONE=your-zone

# Session flags and pins
SESSION_FLAGS_SECRET=replace-with-random
PIN_TOKEN_SECRET=replace-with-random

# Encryption key for PIN encryption (AES-256-GCM) - Generate with: openssl rand -hex 32
CIPHER_KEY=replace-with-64-char-hex-string

# Logging
SERVER_LOG_LEVEL=4
NEXT_PUBLIC_LOG_LEVEL=4

