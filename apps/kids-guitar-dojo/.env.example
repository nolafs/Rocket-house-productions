# Copy this file to .env and fill in real secrets. Do NOT commit .env to version control.
PRODUCTION=false
ENVIRONMENT_NAME=local
NEXT_PUBLIC_BASE_URL=http://localhost:3000/
BASE_URL=http://localhost:3000/

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# Mailer
MAILERLITE_API_KEY=your-mailerlite-api-key
MAILERSEND_API_KEY=your-mailersend-api-key

# ReCaptcha (site key is public; secret is private)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret

# Stripe
STRIPE_API_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# BunnyCDN
BUNNYCDN_API_KEY=your-bunnycdn-api-key
BUNNYCDN_STORAGE_ZONE=your-zone

# Session flags and pins
SESSION_FLAGS_SECRET=replace-with-random
PIN_TOKEN_SECRET=replace-with-random

# Logging
SERVER_LOG_LEVEL=4
NEXT_PUBLIC_LOG_LEVEL=4

