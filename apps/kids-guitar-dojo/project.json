{
  "name": "kids-guitar-dojo",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/kids-guitar-dojo",
  "projectType": "application",
  "root": "apps/kids-guitar-dojo",
  "tags": [],
  "nohoist": [
    {
      "@hookform/resolvers": "^3.9.0"
    }
  ],
  "// targets": "to see all targets run: nx show project kids-guitar-dojo --web",
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{workspaceRoot}/apps/kids-guitar-dojo"],
      "defaultConfiguration": "production",
      "options": {
        "root": "apps/kids-guitar-dojo",
        "outputPath": "apps/kids-guitar-dojo",
        "buildLibsFromSource": true
      },
      "configurations": {
        "development": {
          "sourceMap": true
        },
        "production": {
          "sourceMap": false,
          "profile": false,
          "optimization": true
        }
      }
    },
    "dev": {
      "executor": "@nx/next:server",
      "options": {
        "root": "apps/kids-guitar-dojo",
        "port": 3000,
        "buildTarget": "kids-guitar-dojo:build:development",
        "dev": true,
        "turbo": true
      },
      "configurations": {
        "production": {
          "buildTarget": "kids-guitar-dojo:build:production",
          "dev": false
        }
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p apps/kids-guitar-dojo/tsconfig.json --generateTrace .ts-trace"
      }
    },
    "scan": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev & npx react-scan@latest localhost:3000"
      }
    },
    "slicemachine": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [{ "command": "start-slicemachine" }],
        "cwd": "apps/kids-guitar-dojo"
      }
    },
    "prisma": { "command": "prisma" },
    "migrate:status": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "npx prisma migrate status --schema prisma/schema.prisma"
      },
      "cache": false
    },
    "migrate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "npx prisma migrate dev --schema prisma/schema.prisma"
      },
      "cache": false
    },
    "migrate:deploy": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "npx prisma migrate deploy --schema prisma/schema.prisma"
      },
      "cache": false
    },
    "generate-types": { "command": "prisma generate" },
    "generate-types-no-engine": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma generate --schema prisma/schema.prisma"
      }
    },
    "prisma-studio": { "command": "prisma studio" },
    "bundleAnalyzer": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ANALYZE=true nx build kids-guitar-dojo"
      }
    },
    "dev-with-types": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          { "command": "nx run kids-guitar-dojo:generate-types-no-engine" },
          { "command": "nx run kids-guitar-dojo:dev" }
        ],
        "parallel": false
      }
    },
    "build-with-types": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          { "command": "nx run kids-guitar-dojo:generate-types-no-engine" },
          { "command": "nx build kids-guitar-dojo --configuration=production" }
        ],
        "parallel": false
      }
    }
  }
}
